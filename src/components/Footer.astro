---
const lastUpdated = "July 8, 2026";
---

<footer class="site-foot">
  <div class="container site-foot__inner">
    <p>A student research project.</p>
    <p>Last updated {lastUpdated}</p>
  </div>
</footer>

<style>
  .site-foot {
    border-top: 1px solid var(--border);
    margin-top: 2rem;
  }

  .site-foot__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .site-foot p {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--muted-foreground);
    margin: 0;
  }
</style>
