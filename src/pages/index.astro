---
import Base from "../layouts/Base.astro";
import { devlogPosts } from "../data/content";
---

<Base title="Project Cognify">
  <header>
    <h1 class="hero-title">Project Cognify</h1>
    <p class="subtitle">
      Investigating adolescent attention in an age of engineered distraction
    </p>
  </header>

  <div class="prose intro">
    <p>
      Project Cognify is a multi month long student research project investigating
      why students struggle to focus on their schoolwork,
      and if social presence are the 
      main cause or one part of a bigger picture. Three students: <strong>Jonathan</strong> (Founder), <strong>Jeremy</strong>, and <strong>Ryan</strong> (Co-Founders),
      are creating this
      independently from any third party. We have surveyed 30 students,
      reviewed academic literature on adolescent attention and smartphone use,
      and are currently building a prototype called <a href="/cohort">Cohort</a>
      : a tool/app that lets small groups of friends
      study together online, letting people work together without pressure. We are just three students trying to
      understand why it's so easy to focus in certain contexts.
    </p>
  </div>

  <section class="recent">
    <p class="label">Recent devlog entries</p>
    <div class="entries">
      {
        devlogPosts.slice(0, 4).map((post) => (
          <article class="entry">
            <p class="meta">
              <time datetime={post.dateISO}>{post.date}</time>
              {post.author && (
                <>
                  <span>—</span>
                  <span>{post.author}</span>
                </>
              )}
            </p>
            <h3>
              <a href={`/devlog#${post.id}`}>{post.title}</a>
            </h3>
            <p class="entry__excerpt">{post.excerpt}</p>
            <a class="link-sm" href={`/devlog#${post.id}`}>
              read more →
            </a>
          </article>
        ))
      }
    </div>
  </section>
</Base>

<style>
  .intro {
    margin: 3.5rem 0;
  }

  .intro p {
    font-size: 1.06rem;
  }

  .recent {
    margin-top: 3.5rem;
  }

  .recent .entries {
    margin-top: 2rem;
  }
</style>
