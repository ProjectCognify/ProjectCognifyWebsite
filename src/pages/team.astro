---
import Base from "../layouts/Base.astro";
import { team } from "../data/content";
---

<Base title="Meet the Team">
  <h1>Meet the Team</h1>
  <p class="label">Three friends. One question. Countless conversations.</p>

  <div class="prose intro">
    <p>
      We're three high school students who share a curiosity about technology,
      psychology, and how people learn. Project Cognify started with one simple
      observation, but it's grown into something much bigger through research,
      collaboration, and a willingness to challenge our own assumptions.
    </p>
    <p>
      While each of us contributes in different ways, every major decision is
      made together. From brainstorming ideas to reviewing research, conducting
      interviews, and building prototypes, Project Cognify is a team effort from
      start to finish.
    </p>
  </div>

  <div class="members">
    {
      team.map((member) => (
        <article class="member">
          <img
            class="member__photo"
            src={`https://images.unsplash.com/${member.photo}?w=168&h=168&fit=crop&auto=format`}
            alt={`${member.name}, ${member.role}`}
            width="84"
            height="84"
            loading="lazy"
          />
          <div class="member__body">
            <p class="member__head">
              <span class="member__name">{member.name}</span>
              <span class="member__role">{member.role}</span>
            </p>
            {member.bio.map((para) => (
              <p class="member__bio">{para}</p>
            ))}
            <blockquote class="member__quote">“{member.quote}”</blockquote>
          </div>
        </article>
      ))
    }
  </div>

  <section class="prose believe">
    <h2>What We Believe</h2>
    <p>Project Cognify isn't about proving we're right.</p>
    <p>
      It's about asking better questions, following the evidence, and building
      something that could genuinely help students.
    </p>
    <p>We're excited to see where that journey takes us.</p>
  </section>
</Base>

<style>
  .intro {
    margin: 2.5rem 0 3.5rem;
  }

  .members {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .member {
    display: flex;
    gap: 1.75rem;
    align-items: flex-start;
  }

  /* Grayscale placeholder photos (Unsplash) until real photos are added */
  .member__photo {
    flex: 0 0 84px;
    width: 84px;
    height: 84px;
    object-fit: cover;
    background: var(--muted);
    border: 1px solid var(--border);
    filter: grayscale(100%) contrast(1.05);
  }

  .member__body {
    flex: 1;
    min-width: 0;
  }

  .member__head {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin: 0 0 0.75rem;
  }

  .member__name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
  }

  .member__role {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: var(--muted-foreground);
  }

  .member__bio {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.75;
    margin: 0 0 0.9rem;
  }

  .member__quote {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--foreground);
    margin: 0.5rem 0 0;
    padding-left: 1rem;
    border-left: 2px solid var(--primary);
  }

  .believe {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 34rem) {
    .member {
      gap: 1.25rem;
    }

    .member__photo {
      flex-basis: 60px;
      width: 60px;
      height: 60px;
    }
  }
</style>
