---
import Base from "../layouts/Base.astro";
import { devlogPosts } from "../data/content";
---

<Base title="Devlog">
  <h1>Devlog</h1>
  <p class="label">A research journal, in reverse chronological order</p>

  <div class="log">
    {
      devlogPosts.map((post, i) => (
        <article id={post.id} class="post prose">
          {i > 0 && <hr class="post__rule" />}
          <p class="meta">
            <time datetime={post.dateISO}>{post.date}</time>
            <span>—</span>
            <span>{post.author}</span>
          </p>
          <h2 class="post__title">{post.title}</h2>
          {post.body.map((block) =>
            typeof block === "string" ? (
              <p>{block}</p>
            ) : (
              <blockquote class="pullquote">{block.quote}</blockquote>
            )
          )}
        </article>
      ))
    }
  </div>
</Base>

<style>
  .post__rule {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 3.5rem 0;
  }

  .post__title {
    font-size: 1.3rem;
    line-height: 1.35;
    margin: 0.35rem 0 1.25rem;
  }

  .pullquote {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.5;
    font-style: italic;
    color: var(--foreground);
    margin: 1.5rem 0;
    padding-left: 1.1rem;
    border-left: 2px solid var(--primary);
  }
</style>
